{
  "name": "agentation-vanilla",
  "version": "0.1.1",
  "description": "Framework-agnostic browser UI annotations for AI coding feedback",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "unpkg": "./dist/agentation-vanilla.global.js",
  "jsdelivr": "./dist/agentation-vanilla.global.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "examples",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "annotation",
    "feedback",
    "ai",
    "codex",
    "vanilla-js",
    "typescript"
  ],
  "devDependencies": {
    "@types/node": "^20.12.12",
    "jsdom": "^24.1.3",
    "tsup": "^8.2.4",
    "typescript": "^5.5.4",
    "vitest": "^2.1.1"
  }
}
